[sub_resource type="GDScript" id="GDScript_arena"]
script/source = "extends Node2D

func _ready():
	# Enable AI for all fighters but they'll stay stationary
	for fighter in $Fighters.get_children():
		if fighter.has_method(\"set\"):
			fighter.ai_enabled = true
			# Override their movement to stay in place
			fighter.move_speed = 0

func _input(event):
	if event.is_action_pressed(\"ui_accept\"):
		# Respawn all dead fighters
		for fighter in $Fighters.get_children():
			if \"is_dead\" in fighter and fighter.is_dead:
				fighter.respawn()
				fighter.modulate = Color(1, 1, 1, 1)
"

